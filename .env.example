# Copy to .env and adjust. All variables use the XBREACH_ prefix.

# Snowflake identity (2 distinguishes the worker from the ingest's app_id=1).
XBREACH_WORKER_APP_ID=2
XBREACH_WORKER_NODE_ID=1

# Where the ingest stored the raw files (shared volume).
XBREACH_DATA_PATH=/data/xbreach
XBREACH_LOG_LEVEL=INFO

# Postgres (job lifecycle) — provided by the xbreach-ingest stack.
XBREACH_POSTGRES_HOST=postgres
XBREACH_POSTGRES_PORT=5432
XBREACH_POSTGRES_DB=xbreach
XBREACH_POSTGRES_USER=xbreach
XBREACH_POSTGRES_PASSWORD=xbreach

# ClickHouse (leak storage) — native protocol on 9000.
XBREACH_CLICKHOUSE_HOST=clickhouse
XBREACH_CLICKHOUSE_PORT=9000
XBREACH_CLICKHOUSE_DB=xbreach
XBREACH_CLICKHOUSE_USER=xbreach
XBREACH_CLICKHOUSE_PASSWORD=xbreach

# Stable HMAC key for the privacy-preserving email lookup hash. Change it.
XBREACH_HMAC_EMAIL_KEY=change-me-hmac-key-min-32-bytes-long-please

# Processing tuning.
XBREACH_CLICKHOUSE_BATCH_SIZE=50000
XBREACH_PROGRESS_FLUSH_EVERY=10000
XBREACH_MAX_JOB_ERRORS=1000
XBREACH_BANNER_SCAN_LINES=50
XBREACH_STORE_PLAINTEXT_PASSWORD=true
XBREACH_STORE_RAW_LINE=false
XBREACH_WORKER_POLL_INTERVAL_SECONDS=2.0
